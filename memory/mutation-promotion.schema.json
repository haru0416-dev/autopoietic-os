{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autopoietic-os.local/schemas/mutation-promotion.schema.json",
  "type": "object",
  "allOf": [
    {
      "if": {
        "properties": { "status": { "const": "promoted" } },
        "required": ["status"]
      },
      "then": {
        "required": ["verification_id", "verified_root_fingerprint"]
      }
    }
  ],
  "required": [
    "promotion_id",
    "timestamp",
    "mutation_id",
    "goal",
    "phase",
    "status",
    "reason",
    "proposal_fingerprint",
    "promotion_root_fingerprint",
    "parent_genome",
    "target_configuration",
    "changed_paths",
    "checks"
  ],
  "properties": {
    "promotion_id": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" },
    "mutation_id": { "type": "string" },
    "goal": { "type": "string" },
    "phase": { "type": "string" },
    "status": { "enum": ["promoted", "rejected", "error"] },
    "reason": { "type": "string" },
    "verification_id": { "type": "string" },
    "proposal_fingerprint": { "type": "string", "pattern": "^(sha256:[0-9a-f]{64}|unavailable:.+)$" },
    "verified_root_fingerprint": { "type": "string", "pattern": "^(sha256:[0-9a-f]{64}|unavailable:.+)$" },
    "promotion_root_fingerprint": { "type": "string", "pattern": "^(sha256:[0-9a-f]{64}|unavailable:.+)$" },
    "parent_genome": { "type": "string" },
    "target_configuration": { "type": "string" },
    "changed_paths": { "type": "array", "items": { "type": "string" } },
    "changed_organs": { "type": "array", "items": { "type": "string" } },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "command", "status", "stdout", "stderr"],
        "properties": {
          "name": { "type": "string" },
          "command": { "type": "string" },
          "args": { "type": "array", "items": { "type": "string" } },
          "status": { "enum": ["passed", "failed", "error"] },
          "exit_code": { "type": ["integer", "null"] },
          "stdout": { "type": "string" },
          "stderr": { "type": "string" }
        }
      }
    },
    "metadata": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  }
}
